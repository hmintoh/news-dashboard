---
import '../styles/global.css';
import dashboardData from '../data/dashboard.json';
const { lastUpdated, articles } = dashboardData;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stock News Impact Dashboard</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen py-10 px-4">
    <main class="mx-auto max-w-6xl">
      <section class="mb-10 rounded-[2rem] border border-white/10 bg-slate-900/80 p-10 shadow-[0_30px_80px_-30px_rgba(15,23,42,0.85)] backdrop-blur-xl">
        <p class="text-sm uppercase tracking-[0.3em] text-sky-300/75 mb-3">Market pulse</p>
        <h1 class="text-5xl font-black leading-tight text-white mb-4">Stock News Impact Dashboard</h1>
        <p class="max-w-3xl text-slate-300 text-lg leading-8">
          Monitor financial news sentiment, ticker impact, and live stock reaction in one place.
          Updated on {new Date(lastUpdated).toLocaleString()}.
        </p>
      </section>

      {articles.length === 0 ? (
        <div class="bg-slate-900 rounded-[1.5rem] border border-white/10 shadow-xl p-8">
          <p class="text-slate-300">No articles available yet.</p>
        </div>
      ) : (
        articles.map((article) => {
          const badgeClasses =
            article.sentiment === 'positive'
              ? 'bg-emerald-500/15 text-emerald-200 border border-emerald-500/20'
              : article.sentiment === 'negative'
              ? 'bg-rose-500/15 text-rose-200 border border-rose-500/20'
              : 'bg-slate-500/15 text-slate-200 border border-slate-500/20';

          return (
            <article class="mb-6 overflow-hidden rounded-[2rem] border border-white/10 bg-slate-900/85 shadow-[0_40px_80px_-40px_rgba(15,23,42,0.8)]">
              <div class="p-8 sm:p-10">
                <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
                  <div class="max-w-3xl">
                    <a
                      href={article.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-3xl font-semibold text-white transition hover:text-sky-300"
                    >
                      {article.title}
                    </a>
                    <p class="mt-3 text-sm uppercase tracking-[0.25em] text-slate-500">
                      {new Date(article.date).toLocaleString()}
                    </p>
                  </div>
                  <span class={`inline-flex items-center rounded-full px-4 py-2 text-sm font-semibold uppercase tracking-[0.15em] ${badgeClasses}`}>
                    {article.sentiment}
                  </span>
                </div>

                <p class="mt-6 text-slate-300 leading-8">{article.impact}</p>

                <div class="mt-8 grid gap-4 sm:grid-cols-2">
                  {article.tickers.length > 0 ? (
                    article.tickers.map((ticker) => (
                      <div class="rounded-3xl border border-white/10 bg-slate-950/80 p-5 shadow-[inset_0_0_0_1px_rgba(148,163,184,0.05)]">
                        <div class="flex items-center justify-between gap-4">
                          <div>
                            <p class="text-base font-semibold tracking-wide text-white">{ticker.symbol}</p>
                            <p class="mt-1 text-sm text-slate-400">Price: {ticker.price ?? 'N/A'}</p>
                          </div>
                          <div
                            class={`rounded-full px-3 py-2 text-sm font-semibold ${
                              typeof ticker.change === 'number' && ticker.change < 0
                                ? 'bg-rose-500/15 text-rose-200'
                                : typeof ticker.change === 'number'
                                ? 'bg-emerald-500/15 text-emerald-200'
                                : 'bg-slate-500/15 text-slate-200'
                            }`}
                          >
                            {ticker.change == null ? 'N/A' : `${ticker.change.toFixed(2)}%`}
                          </div>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div class="rounded-3xl border border-white/10 bg-slate-950/80 p-5 text-slate-400">
                      No affected tickers identified.
                    </div>
                  )}
                </div>
              </div>
            </article>
          );
        })
      )}
    </main>
  </body>
</html>